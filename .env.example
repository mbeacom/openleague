# Database (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Optional: Force Prisma migration deployment during Vercel preview/local builds.
# Only enable when the build targets a safe, isolated database.
# OPENLEAGUE_RUN_MIGRATIONS_ON_BUILD="false"

# Auth.js Configuration
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Email Service (Mailchimp Transactional)
# Get your API key from: https://mandrillapp.com/settings
MAILCHIMP_API_KEY=""
EMAIL_FROM="noreply@openl.app"

# Cron job authentication (required when cron endpoints are enabled)
# Generate with: openssl rand -base64 32
# CRON_SECRET=""

# Protected uptime/readiness checks
# Set the same generated value in Vercel and GitHub Actions secrets.
# Generate with: openssl rand -base64 32
# UPTIME_CHECK_TOKEN=""

# Analytics and Tracking
# Umami Analytics (privacy-friendly, open-source)
# Get your website ID from: https://cloud.umami.is
# Leave empty to disable Umami tracking
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# Google Analytics 4 Measurement ID
# Leave empty to disable GA4. The app respects browser Do Not Track/GPC and stored denial consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Optional: Error tracking (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Optional: Performance monitoring
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# Optional: Scheduled uptime monitoring workflow targets
# DOCS_PAGES_DOMAIN="openleague.dev"
# Format: comma-separated URLs or name=url pairs. Defaults to public main and docs sites locally.
# The GitHub Actions workflow also checks the protected health endpoint.
# UPTIME_CHECK_URLS="main=https://openl.app,docs=https://openleague.dev,health=https://openl.app/api/health"
# UPTIME_CHECK_AUTH_TARGETS="health"
# UPTIME_CHECK_AUTH_ALLOWED_HOSTS="openl.app,openhockey.app"
# UPTIME_CHECK_TIMEOUT_MS="10000"

# Marketing and Conversion Tracking
# Session recording is intentionally not enabled by default; choose/configure a vendor only with a consent policy.
# NEXT_PUBLIC_HOTJAR_ID=""
# NEXT_PUBLIC_MIXPANEL_TOKEN=""

# Optional: Advertising (disabled by default)
# Set NEXT_PUBLIC_ADS_ENABLED="true" and provide AdSense IDs to enable public ad slots.
NEXT_PUBLIC_ADS_ENABLED="false"
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=""
NEXT_PUBLIC_GOOGLE_ADSENSE_MARKETING_SLOT=""
NEXT_PUBLIC_GOOGLE_ADSENSE_DASHBOARD_SLOT=""

# Optional: For future AWS migration
# AWS_REGION="us-east-1"

# Payments: Stripe Connect (optional — rink session purchasing)
# When unset, paid registration falls back to free opt-in and checkout is disabled.
# Each rink connects its own Stripe account; OpenLeague uses direct charges.
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Connect webhook signing secret (events from connected accounts) — see app/api/webhooks/stripe
# STRIPE_CONNECT_WEBHOOK_SECRET="whsec_..."
# Optional platform application fee in basis points (250 = 2.5%). Default 0.
# STRIPE_PLATFORM_FEE_BPS="0"
