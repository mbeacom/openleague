  lessonOfferingId String?
  lessonOffering   LessonOffering? @relation(fields: [lessonOfferingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("SessionRegistrant", fields: [userId], references: [id], onDelete: Cascade)

