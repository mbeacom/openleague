  // Snapshot of participant details at registration time.
  participantName  String
  participantEmail String
  participantPhone String?
  skillLevelNote   String?
  notes            String?
  quantity         Int                       @default(1)
  // Price snapshot in the smallest currency unit (cents). amountTotal = unitAmount * quantity.
  unitAmount       Int                       @default(0)
  amountTotal      Int                       @default(0)
  currency         String                    @default("USD")
  confirmedAt      DateTime?
  canceledAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

