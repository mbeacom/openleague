{
  "name": "openleague",
  "version": "0.62.2",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "dev:wake": "tsx scripts/wake-db.ts && bun run dev",
    "build": "bun --bun next build",
    "vercel:build": "bun scripts/vercel-build.mjs",
    "start": "bun --bun next start",
    "lint": "eslint .",
    "type": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "postinstall": "prisma generate --config prisma/prisma.config.ts",
    "db:studio": "prisma studio --config prisma/prisma.config.ts",
    "db:push": "prisma db push --config prisma/prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config prisma/prisma.config.ts",
    "db:migrate:reset": "prisma migrate reset --config prisma/prisma.config.ts",
    "db:generate": "prisma generate --config prisma/prisma.config.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:wake": "tsx scripts/wake-db.ts",
    "validate-env": "tsx scripts/validate-env.js",
    "docs:build-pages": "tsx scripts/build-docs-pages.ts",
    "uptime:check": "tsx scripts/check-uptime.ts",
    "validate-deployment-config": "tsx scripts/validate-deployment-config.ts",
    "smoke": "bun scripts/smoke-test.ts",
    "deployment:check": "bun run validate-deployment-config && bun run docs:build-pages"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mailchimp/mailchimp_transactional": "^1.4.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/material-nextjs": "^7.3.10",
    "@mui/x-date-pickers": "^8.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@next/mdx": "^16.2.9",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.5.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.0",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
